{
  "name": "maverick-ambitions",
  "version": "0.9.0",
  "private": true,
  "type": "module",
  "description": "Maverick Ambitions — a deep, generational business simulation game inspired by Big Ambitions. iPhone-first, iPad and Desktop adaptive.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "format": "prettier --write .",
    "smoke": "npm run smoke:purchase-tick && npm run smoke:events && npm run smoke:hospitality && npm run smoke:cafe && npm run smoke:real-estate && npm run smoke:business-loans && npm run smoke:bankruptcy",
    "smoke:purchase-tick": "tsx scripts/smoke-purchase-tick.ts",
    "smoke:events": "tsx scripts/smoke-events.ts",
    "smoke:hospitality": "tsx scripts/smoke-hospitality.ts",
    "smoke:cafe": "tsx scripts/smoke-cafe.ts",
    "smoke:real-estate": "tsx scripts/smoke-real-estate.ts",
    "smoke:business-loans": "tsx scripts/smoke-business-loans.ts",
    "smoke:bankruptcy": "tsx scripts/smoke-bankruptcy.ts"
  },
  "dependencies": {
    "clsx": "2.1.1",
    "date-fns": "3.6.0",
    "immer": "10.1.1",
    "nanoid": "5.0.7",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "6.26.2",
    "tailwind-merge": "2.3.0",
    "zustand": "4.5.2"
  },
  "devDependencies": {
    "@types/node": "20.12.12",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "@typescript-eslint/eslint-plugin": "7.13.0",
    "@typescript-eslint/parser": "7.13.0",
    "@vitejs/plugin-react": "4.3.1",
    "autoprefixer": "10.4.19",
    "eslint": "8.57.0",
    "eslint-plugin-react": "7.34.2",
    "eslint-plugin-react-hooks": "4.6.2",
    "postcss": "8.4.38",
    "prettier": "3.3.0",
    "prettier-plugin-tailwindcss": "0.6.1",
    "tailwindcss": "3.4.4",
    "tsx": "4.19.0",
    "typescript": "5.4.5",
    "vite": "5.3.1",
    "vite-tsconfig-paths": "4.3.2"
  },
  "engines": {
    "node": ">=18.17.0"
  }
}
