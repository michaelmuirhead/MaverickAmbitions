{
  "name": "maverick-ambitions",
  "version": "0.5.0",
  "private": true,
  "description": "Maverick Ambitions — a deep, generational business simulation game inspired by Big Ambitions. iPhone-first, iPad and Desktop adaptive.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "smoke": "npm run smoke:events && npm run smoke:hospitality && npm run smoke:cafe && npm run smoke:real-estate",
    "smoke:events": "tsx scripts/smoke-events.ts",
    "smoke:hospitality": "tsx scripts/smoke-hospitality.ts",
    "smoke:cafe": "tsx scripts/smoke-cafe.ts",
    "smoke:real-estate": "tsx scripts/smoke-real-estate.ts"
  },
  "dependencies": {
    "next": "14.2.5",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zustand": "4.5.2",
    "immer": "10.1.1",
    "clsx": "2.1.1",
    "tailwind-merge": "2.3.0",
    "date-fns": "3.6.0",
    "nanoid": "5.0.7"
  },
  "devDependencies": {
    "@types/node": "20.12.12",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "10.4.19",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.5",
    "postcss": "8.4.38",
    "prettier": "3.3.0",
    "prettier-plugin-tailwindcss": "0.6.1",
    "tailwindcss": "3.4.4",
    "tsx": "4.19.0",
    "typescript": "5.4.5"
  },
  "engines": {
    "node": ">=18.17.0"
  }
}
